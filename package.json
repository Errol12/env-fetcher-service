{
  "name": "env-fetcher-service",
  "version": "2.0.0",
  "description": "The following package fetches aws stored parametes and aws secret manager",
  "author": "Errol Fernandes",
  "license": "MIT",
  "main": "src/index.js",
  "files": [
    "src/**/*",
    "*.md"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.js\" \"test/**/*.js\" --fix"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.922.0",
    "@aws-sdk/client-ssm": "^3.922.0",
    "joi": "^18.0.1"
  },
  "devDependencies": {
    "eslint": "^9.39.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "jest": "^30.2.0",
    "prettier": "^3.6.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Errol12/env-fetcher-service.git"
  },
  "jest": {
    "testEnvironment": "node",
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  }
}
